generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum TenantStatus {
  PENDING
  ACTIVE
  CHECKED_OUT
}

enum TenancyStatus {
  ACTIVE
  COMPLETED
  TERMINATED
}

model Property {
  id      String @id @default(cuid())
  name    String
  type    String
  address String

  agreementStart DateTime
  agreementEnd   DateTime

  totalRooms     Int
  availableRooms Int

  status String

  rooms Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id          String     @id @default(cuid())
  roomNumber  String
  floor       String?
  monthlyRent Float
  status      RoomStatus

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenancies Tenancy[]
}

model Tenant {
  id String @id @default(cuid())

  fullName String
  phone    String
  email    String?

  icPassport String

  nationality String?
  gender      String?

  emergencyContactName  String?
  emergencyContactPhone String?

  status TenantStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenancies Tenancy[]
}

model Tenancy {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  roomId String
  room   Room   @relation(fields: [roomId], references: [id])

  moveInDate  DateTime
  moveOutDate DateTime?

  monthlyRental Float

  securityDeposit Float
  utilityDeposit  Float

  status TenancyStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
