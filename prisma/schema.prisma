generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Property {
  id             String   @id @default(cuid())
  name           String
  type           String
  address        String

  agreementStart DateTime
  agreementEnd   DateTime

  totalRooms     Int
  availableRooms Int

  status         String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}